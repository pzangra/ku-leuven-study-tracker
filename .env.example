# .env.example
ICS_URL="https://outlook.office365.com/owa/calendar/.../calendar.ics"
USER_AGENT="Your User Agent String"
HTTP_ACCEPT="text/calendar, application/octet-stream, */*"
HTTP_ACCEPT_ENCODING="gzip, deflate, br"
HTTP_CONNECTION="keep-alive"
TAILSCALE_IP="100.X.X.X"
PORT="8080"
DB_PATH="/opt/study-tracker/study_data.db"
HEATMAP_PATH="/opt/study-tracker/study_heatmap.png"
TRACKER_DIR="/opt/study-tracker"
DASHBOARD_PATH="/opt/study-tracker/dashboard.html"
